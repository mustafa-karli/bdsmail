# BDS Mail Configuration

# Comma-separated list of domains served by this mail server
BDS_DOMAINS=domain1.com,domain2.com

# Server ports
BDS_SMTP_PORT=25
BDS_POP3_PORT=110
BDS_IMAP_PORT=143
BDS_HTTPS_PORT=443
BDS_HTTP_PORT=80          # Plain HTTP for ACME certificate challenges

# TLS certificates (managed automatically by certbot via deploy.sh)
BDS_TLS_CERT=/etc/letsencrypt/live/mail.domain1.com/fullchain.pem
BDS_TLS_KEY=/etc/letsencrypt/live/mail.domain1.com/privkey.pem

# GCP Cloud Storage bucket for mail bodies
BDS_GCS_BUCKET=bdsmail-bodies

# PostgreSQL connection string
DATABASE_URL=postgres://bdsmail:password@10.x.x.x:5432/bdsmail?sslmode=require

# DKIM signing (keys generated automatically by deploy.sh or -adddomain)
BDS_DKIM_KEY_DIR=/opt/bdsmail/dkim
BDS_DKIM_SELECTOR=default

# Admin secret for domain management (web UI at /admin/domains and CLI -adddomain)
BDS_ADMIN_SECRET=your-secret-here

# ACME webroot for certbot certificate challenges
BDS_ACME_WEBROOT=/opt/bdsmail/acme

# Path to .env file (for persisting domain additions)
BDS_ENV_FILE=/opt/bdsmail/.env

# GCP credentials (if not using VM default service account)
GOOGLE_APPLICATION_CREDENTIALS=/opt/bdsmail/sa-key.json
